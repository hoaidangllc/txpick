# Supabase (Auth + Database)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI (AI Agent — Phase 6 / Pro feature)
# WARNING: Calling OpenAI directly from the browser exposes your key.
# For production, route AI calls through a Supabase Edge Function.
VITE_OPENAI_API_KEY=sk-...

# App config
VITE_APP_URL=https://txpick.com

# Web Push reminders
# Generate with: npm run push:keys
VITE_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# Optional server alias. If empty, API falls back to VITE_SUPABASE_URL.
SUPABASE_URL=
# Optional: reminder cron lookback window in minutes.
REMINDER_LOOKBACK_MINUTES=8
